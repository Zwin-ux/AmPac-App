{
  "expo": {
    "name": "AmPac Capital",
    "slug": "ampac-business-capital",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ampac",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ampac.borrower",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app uses the photo library to let you upload profile pictures and share images in chat.",
        "NSCameraUsageDescription": "This app uses the camera to let you take profile pictures and share photos in chat.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ampac.borrower",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "graphClientId": "${EXPO_PUBLIC_GRAPH_CLIENT_ID}",
      "graphTenantId": "common",
      "graphUseProxy": true,
      "graphScopes": [
        "Calendars.ReadWrite",
        "offline_access"
      ],
      "scheme": "ampac",
      "eas": {
        "projectId": "d4d70bfc-70cd-4a73-a5c2-bd56d33b2474"
      }
    },
    "owner": "ampac",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d4d70bfc-70cd-4a73-a5c2-bd56d33b2474"
    }
  }
}
