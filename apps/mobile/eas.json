{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_GRAPH_CLIENT_ID": "your_development_client_id"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_GRAPH_CLIENT_ID": "your_staging_client_id"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_GRAPH_CLIENT_ID": "your_production_client_id"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
