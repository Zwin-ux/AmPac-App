rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return getUserData().role == 'ampac_staff';
    }

    function isAdmin() {
      return getUserData().role == 'admin' || getUserData().staffRole == 'admin';
    }

    // --- USERS ---
    match /users/{userId} {
      // Users can read and write their own profile
      // Staff can read all user profiles
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // --- APPLICATIONS ---
    match /applications/{appId} {
      // Users can create applications if they are authenticated
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can read their own applications, Staff can read all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isStaff());
      
      // Users can update their own applications, BUT NOT THE STATUS
      allow update: if isAuthenticated() 
                    && resource.data.userId == request.auth.uid
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'adminNotes', 'assignedTo']));
                    
      // Staff can update everything
      allow update: if isAuthenticated() && isStaff();
    }

    // --- ROOMS ---
    match /rooms/{roomId} {
      // Public read
      allow read: if true;
      // Only admins can write rooms
      allow write: if isAuthenticated() && isAdmin();
    }

    // --- BOOKINGS ---
    match /bookings/{bookingId} {
      // Users can read their own bookings, Staff can read all
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isStaff());
      
      // Users can create bookings
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // No deletions allowed for audit trail
      allow delete: if false;
    }
    
    // --- BUSINESSES (Network) ---
    match /businesses/{businessId} {
        allow read: if true;
        allow write: if isAuthenticated() && isStaff();
    }
  }
}
