# Server Config
PROJECT_NAME="AmPac Brain 🧠"
VERSION="0.1.0"
API_V1_STR="/api/v1"

# OpenAI (Required for Phase 4)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Firebase
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Microsoft Graph (Optional - Mocked if missing)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Ventures API (Optional - Mocked by default)
VENTURES_USERNAME=
VENTURES_PASSWORD=
VENTURES_MOCK_MODE=True

# ShareFile (Optional)
SHAREFILE_CLIENT_ID=
SHAREFILE_CLIENT_SECRET=
SHAREFILE_SUBDOMAIN=ampac
